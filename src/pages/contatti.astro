---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import ContactForm from "../components/ContactForm.astro";
import SocialLinks from "../components/SocialLinks.astro";
import { CONTACTS } from "../data/contacts";

const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebPage", name: "Contatti" },
  {
    "@context": "https://schema.org",
    "@type": "ContactPoint",
    telephone: CONTACTS.phone,
    email: CONTACTS.email,
    contactType: "customer service",
    areaServed: "IT",
  },
];

// Coordinate ottenute via geocodifica (Nominatim/OpenStreetMap) di "Viale della Libertà 39, 81016
// Piedimonte Matese (CE)": il servizio risolve a livello di via (senza civico esatto disponibile),
// quindi il pin è posizionato su Viale della Libertà, non sul numero civico preciso.
const mapLat = 41.3548661;
const mapLon = 14.3741648;
const mapBbox = [mapLon - 0.004, mapLat - 0.002, mapLon + 0.004, mapLat + 0.002].join(",");
const mapMarker = `${mapLat},${mapLon}`;
---

<BaseLayout
  title="Contatti"
  description="Contatta Passi Condivisi: indirizzo, telefono, email e modulo di contatto della cooperativa sociale ETS di Piedimonte Matese (CE)."
  canonicalPath="/contatti"
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-4xl px-4 pt-8 sm:px-6">
    <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Contatti" }]} />
  </div>
  <header class="mx-auto max-w-3xl px-4 py-12 text-center sm:px-6">
    <h1 class="text-4xl font-semibold text-ink sm:text-5xl">Contatti</h1>
    <p class="mt-4 text-lg text-ink/70">
      Siamo a Piedimonte Matese: scrivici, chiamaci o vieni a trovarci. Rispondiamo il prima possibile.
    </p>
  </header>

  <ScrollReveal as="section">
    <div class="mx-auto grid max-w-5xl gap-6 px-4 py-8 sm:px-6 lg:grid-cols-5 lg:items-start">
      <div class="space-y-6 lg:col-span-2">
        <div class="rounded-3xl bg-white p-6 shadow-sm sm:p-8">
          <SectionHeading title="I nostri recapiti" />
          <ul class="mt-6 space-y-5 text-ink/80">
            <li class="flex items-start gap-3">
              <span
                class="mt-0.5 flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full bg-brand-purple/10 text-brand-purple"
                aria-hidden="true"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path d="M12 21s-7-6.02-7-11.5A7 7 0 0 1 19 9.5C19 14.98 12 21 12 21Z" />
                  <circle cx="12" cy="9.5" r="2.5" />
                </svg>
              </span>
              <span>
                {CONTACTS.address.street}<br />
                {CONTACTS.address.postalCode} {CONTACTS.address.city} ({CONTACTS.address.province})
              </span>
            </li>
            <li class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full bg-brand-purple/10 text-brand-purple"
                aria-hidden="true"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path d="M4 4h16v16H4z" opacity="0" />
                  <path d="M3.5 5.5h17v13h-17z" />
                  <path d="m3.5 6 8.5 7 8.5-7" />
                </svg>
              </span>
              <a href={`mailto:${CONTACTS.email}`} class="underline decoration-brand-purple/30 underline-offset-2 hover:decoration-brand-purple">
                {CONTACTS.email}
              </a>
            </li>
            <li class="flex items-center gap-3">
              <span
                class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full bg-brand-purple/10 text-brand-purple"
                aria-hidden="true"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path
                    d="M6.6 10.8c1.4 2.8 3.8 5.2 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.4c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.4 0 .8-.2 1l-2.2 2.2Z"
                  />
                </svg>
              </span>
              <a href={`tel:${CONTACTS.phone}`} class="underline decoration-brand-purple/30 underline-offset-2 hover:decoration-brand-purple">
                {CONTACTS.phoneDisplay}
              </a>
            </li>
          </ul>
          <div class="mt-6 border-t border-black/5 pt-6">
            <p class="text-sm font-semibold text-ink">Seguici</p>
            <div class="mt-3"><SocialLinks /></div>
          </div>
        </div>

        <div class="overflow-hidden rounded-3xl border border-black/10 bg-white shadow-sm">
          <iframe
            title="Mappa della sede di Passi Condivisi"
            src={`https://www.openstreetmap.org/export/embed.html?bbox=${mapBbox}&layer=mapnik&marker=${mapMarker}`}
            class="h-64 w-full sm:h-72"
            loading="lazy"
          ></iframe>
          <p class="px-4 py-3 text-xs text-ink/60">
            {CONTACTS.address.street}, {CONTACTS.address.city} ({CONTACTS.address.province})
          </p>
        </div>
      </div>

      <div class="rounded-3xl bg-white p-6 shadow-sm sm:p-8 lg:col-span-3">
        <SectionHeading title="Scrivici" subtitle="Compila il modulo: ti risponderemo il prima possibile." />
        <div class="mt-6"><ContactForm /></div>
      </div>
    </div>
  </ScrollReveal>
</BaseLayout>
