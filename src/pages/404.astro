---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Pagina non trovata"
  description="La pagina richiesta non esiste o è stata spostata."
  canonicalPath="/404"
  noindex
>
  <div class="mx-auto max-w-2xl px-4 py-24 text-center sm:px-6">
    <h1 class="text-4xl font-semibold text-ink">Pagina non trovata</h1>
    <p class="mt-4 text-ink/70">La pagina che cerchi non esiste o è stata spostata.</p>
    <a href="/" class="mt-8 inline-block rounded-full bg-brand-purple px-6 py-3 font-semibold text-white">
      Torna alla home
    </a>
  </div>
</BaseLayout>
